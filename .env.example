# ===== Telegram =====
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_id_here

# ===== Claude API =====
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_TIMEOUT_SECONDS=540
ANTHROPIC_MAX_RETRIES=0
ANTHROPIC_GLOBAL_CONCURRENCY=4

# ===== Системный промпт =====
SYSTEM_PROMPT=Ты полезный ассистент. Текущее время передаётся в каждом сообщении.

# ===== Часовой пояс по умолчанию =====
DEFAULT_TIMEZONE=Europe/Moscow

# ===== Расценки (USD за токен, актуальны на март 2026) =====
# Claude Haiku 4.5
ANTHROPIC_PRICE_INPUT=0.000001       # $1.00 / 1M токенов
ANTHROPIC_PRICE_OUTPUT=0.000005      # $5.00 / 1M токенов
# Claude Sonnet 4.6
ANTHROPIC_PRICE_INPUT_SONNET=0.000003
ANTHROPIC_PRICE_OUTPUT_SONNET=0.000015

# ===== Контекст и саммаризация =====
SUMMARY_TRIGGER_TOKENS=0.85    # порог заполнения контекстного окна (0..1)
SUMMARY_TRIGGER_HOURS=72       # часов тишины для триггера по времени
SUMMARY_KEEP_LAST=10           # последних диалогов (пар) не сжимать

# ===== Лимиты =====
MAX_FILE_MB=20
MAX_LOG_MB=5

# ===== Напоминания =====
REMINDER_POLL_INTERVAL=10s
REMINDER_BATCH_LIMIT=50
REMINDER_LOOKAHEAD=2s
REMINDER_JITTER=2s
REMINDER_DEFAULT_SILENT=1

# ===== Режим отладки =====
DEBUG_MODE=0

# ===== SearXNG (веб-поиск) =====
# SEARCH_ENGINE: auto | searxng | native
#   auto    — проверяет SearXNG, если недоступен — переключается на нативный Anthropic
#   searxng — только SearXNG (native не используется)
#   native  — только нативный Anthropic web_search ($0.01/запрос)
SEARCH_ENGINE=auto
SEARXNG_URL=http://localhost:8888
